<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.claude-usage"
          path="/org/gnome/shell/extensions/claude-usage/">
    <key name="colo" type="s">
      <default>'NRT'</default>
      <summary>Expected Cloudflare colo</summary>
      <description>校验请求前 cdn-cgi/trace 的 colo 字段</description>
    </key>
    <key name="loc" type="s">
      <default>'JP'</default>
      <summary>Expected loc</summary>
      <description>校验请求前 cdn-cgi/trace 的 loc 字段</description>
    </key>
    <key name="credentials-path" type="s">
      <default>''</default>
      <summary>credentials.json 路径</summary>
      <description>留空自动查找 ~/.claude/.credentials.json</description>
    </key>
    <key name="interval-min" type="i">
      <default>3</default>
      <range min="1" max="180"/>
      <summary>刷新间隔（分钟）</summary>
    </key>
    <key name="manual-first" type="b">
      <default>false</default>
      <summary>开机后首次必须手动刷新</summary>
    </key>
  </schema>
</schemalist>
