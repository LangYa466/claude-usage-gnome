<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.claude-usage"
          path="/org/gnome/shell/extensions/claude-usage/">
    <key name="colo" type="s">
      <default>'NRT'</default>
      <summary>Expected Cloudflare colo</summary>
    </key>
    <key name="loc" type="s">
      <default>'JP'</default>
      <summary>Expected loc (country code)</summary>
    </key>
    <key name="credentials-path" type="s">
      <default>''</default>
      <summary>Path to credentials.json</summary>
      <description>Empty = auto-detect ~/.claude/.credentials.json</description>
    </key>
    <key name="interval-min" type="i">
      <default>3</default>
      <range min="1" max="180"/>
      <summary>Refresh interval (minutes)</summary>
    </key>
    <key name="manual-first" type="b">
      <default>false</default>
      <summary>Require manual first refresh</summary>
    </key>
    <key name="language" type="s">
      <choices>
        <choice value="auto"/>
        <choice value="en"/>
        <choice value="zh-CN"/>
      </choices>
      <default>'auto'</default>
      <summary>UI language</summary>
      <description>auto follows the system locale; otherwise forced to English or Simplified Chinese</description>
    </key>
  </schema>
</schemalist>
